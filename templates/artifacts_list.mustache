{{!
    @template mod_plugnmeet/artifacts_list

    Example context (json):
    {
        "artifacts": [
            {
                "artifact_id": "artifact123",
                "type": "Meeting Summary",
                "created": "2023-10-27 10:00:00",
                "view_url": "http://example.com/view"
            }
        ],
        "paging_bar": "<nav>Paging bar HTML</nav>"
    }
}}
<table class="generaltable table-hover w-100 mb-2">
    <thead>
        <tr>
            <th>{{#str}}artifact_id, mod_plugnmeet{{/str}}</th>
            <th class="text-center">{{#str}}type, mod_plugnmeet{{/str}}</th>
            <th class="text-center">{{#str}}created_at, mod_plugnmeet{{/str}}</th>
            <th class="text-center">{{#str}}actions, mod_plugnmeet{{/str}}</th>
        </tr>
    </thead>
    <tbody>
        {{#artifacts}}
        <tr>
            <td>{{artifact_id}}</td>
            <td class="text-center">{{type}}</td>
            <td class="text-center">{{created}}</td>
            <td class="text-center">
                <a href="{{view_url}}" class="btn btn-sm btn-info">{{#str}}view, mod_plugnmeet{{/str}}</a>
            </td>
        </tr>
        {{/artifacts}}
    </tbody>
</table>

{{{paging_bar}}}

{{!
    @template mod_plugnmeet/recordings_list

    Example context (json):
    {
        "recordings": [
            {
                "record_id": "rec123",
                "creation_time": "2023-10-27 10:00:00",
                "room_creation_time": "2023-10-27 09:00:00",
                "file_size": "120 MB",
                "view_url": "http://example.com/view"
            }
        ],
        "paging_bar": "<nav>Paging bar HTML</nav>"
    }
}}
<table class="generaltable table-hover w-100 mb-2">
    <thead>
        <tr>
            <th>{{#str}}recording_id, mod_plugnmeet{{/str}}</th>
            <th class="text-center">{{#str}}recording_creation_time, mod_plugnmeet{{/str}}</th>
            <th class="text-center">{{#str}}room_creation_time, mod_plugnmeet{{/str}}</th>
            <th class="text-center">{{#str}}file_size, mod_plugnmeet{{/str}}</th>
            <th class="text-center">{{#str}}actions, mod_plugnmeet{{/str}}</th>
        </tr>
    </thead>
    <tbody>
        {{#recordings}}
        <tr>
            <td>{{record_id}}</td>
            <td class="text-center">{{creation_time}}</td>
            <td class="text-center">{{room_creation_time}}</td>
            <td class="text-center">{{file_size}}</td>
            <td class="text-center">
                <a href="{{view_url}}" class="btn btn-sm btn-info">{{#str}}view, mod_plugnmeet{{/str}}</a>
            </td>
        </tr>
        {{/recordings}}
    </tbody>
</table>

{{{paging_bar}}}

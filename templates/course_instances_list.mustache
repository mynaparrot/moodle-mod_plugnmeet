{{!
    @template mod_plugnmeet/course_instances_list

    Example context (json):
    {
        "has_plugnmeets": true,
        "table": {
            "headers": ["Week", "Name"],
            "rows": [
                {
                    "section": "1",
                    "link": {
                        "url": "http://example.com/mod/plugnmeet/view.php?id=1",
                        "text": "My PlugNmeet Activity",
                        "dimmed": false
                    }
                },
                {
                    "section": "2",
                    "link": {
                        "url": "http://example.com/mod/plugnmeet/view.php?id=2",
                        "text": "Another PlugNmeet Activity (hidden)",
                        "dimmed": true
                    }
                }
            ]
        },
        "no_plugnmeets_message": "There are no PlugNmeet activities yet.",
        "no_plugnmeets_url": "http://example.com/course/view.php?id=1",
        "strplugnmeets": "PlugNmeet Activities"
    }
}}
<div class="mod_plugnmeet_index">
    {{#has_plugnmeets}}
        <table class="generaltable moodle-table">
            <thead>
                <tr>
                    {{#table.headers}}
                        <th scope="col">{{.}}</th>
                    {{/table.headers}}
                </tr>
            </thead>
            <tbody>
                {{#table.rows}}
                    <tr>
                        {{#section}}
                            <td class="c0">{{section}}</td>
                        {{/section}}
                        <td class="c1">
                            <a href="{{link.url}}" {{#link.dimmed}}class="dimmed"{{/link.dimmed}}>{{link.text}}</a>
                        </td>
                    </tr>
                {{/table.rows}}
            </tbody>
        </table>
    {{/has_plugnmeets}}
    {{^has_plugnmeets}}
        <div class="alert alert-info">
            {{no_plugnmeets_message}} <a href="{{no_plugnmeets_url}}">{{#strplugnmeets}}Add one now.{{/strplugnmeets}}</a>
        </div>
    {{/has_plugnmeets}}
</div>